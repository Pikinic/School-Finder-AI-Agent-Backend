NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_finder
FRONTEND_URL=http://localhost:5173
COOKIE_SECRET=replace-with-another-random-secret
JWT_SECRET=replace-with-a-long-random-jwt-secret
DOCS_ENABLED=true
LOG_LEVEL=debug

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=School Finder AI <no-reply@example.com>

# Local development bootstrap only. prisma/seed.ts rejects production execution.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123
SEED_ADMIN_FULL_NAME=System Administrator
